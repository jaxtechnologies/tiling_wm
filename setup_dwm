    ##### list all and grep for keyword
    ##### gsettings list-recursively | grep <keyword>
    ##### gsettings list-recursively org.cinnamon.settings-daemon.plugins.power
    gsettings set org.cinnamon.desktop.background picture-uri 'file:///usr/share/backgrounds/linuxmint/ktee_linuxmint.png' 2>&1 | tee -a $LOG
    gsettings set org.cinnamon.desktop.interface clock-use-24h false 2>&1 | tee -a $LOG
    gsettings set org.cinnamon.desktop.session idle-delay 0 2>&1 | tee -a $LOG
    gsettings set org.gnome.settings-daemon.plugins.power idle-dim false 2>&1 | tee -a $LOG
