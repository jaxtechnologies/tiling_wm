##################################################################################################
#################################### INSTALL BASE APPS ###########################################
##################################################################################################

sudo pacman -Syu git vim gcc make base-devel pkgconf xorg xorg-xinit feh ttf-mononoki-nerd ranger lightdm lightdm-gtk-greeter openssh firefox qutebrowser mousepad
