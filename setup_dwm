##################################################################################################
install_base_apps() {
    clear
    sudo nala install alacritty curl dos2unix exa fish fonts-powerline openssh-server vim neovim tldr xrdp sxhkd gxmessage -y 2>&1

    if id -nG xrdp | grep -qw ssl-cert; then
        echo "User xrdp already exists in ssl-cert group, skipping..." 2>&1 | tee -a $LOG
        sleep 3
    else
        sudo adduser xrdp ssl-cert 2>&1 | tee -a $LOG
        sleep 3
    fi

    [ ! -d ~/.config/alacritty ] && mkdir -p ~/.config/alacritty 2>&1 | tee -a $LOG
    [ ! -d ~/.config/sxhkd ] && mkdir -p ~/.config/sxhkd 2>&1 | tee -a $LOG
    cp $INSTALL_PATH/configs/alacritty/alacritty.yml ~/.config/alacritty/ 2>&1 | tee -a $LOG
    cp $INSTALL_PATH/configs/.bashrc_lmde6 ~/.bashrc 2>&1 | tee -a $LOG
    cp $INSTALL_PATH/configs/.vimrc ~/ 2>&1 | tee -a $LOG
    cp $INSTALL_PATH/configs/keybindings ~/keybindings 2>&1 | tee -a $LOG
    cp $INSTALL_PATH/configs/sxhkd/sxhkdrc ~/.config/sxhkd/ 2>&1 | tee -a $LOG
    cp $INSTALL_PATH/configs/autostart/sxhkd.desktop ~/.config/autostart/ 2>&1 | tee -a $LOG
    unzip $INSTALL_PATH/packages/synth-shell.zip -d $INSTALL_PATH/packages/ 2>&1 | tee -a $LOG
    clear
    echo -ne "
    Synth-Shell Install Options
    NOTE: Type entry, but don't press enter...
    ================================================
    install   =  i (default)
    user      =  u (default)
    greeter   =  n
    prompt    =  Y (default)
    b-ls      =  n
    alias     =  n
    b-history =  n	
    "
    echo ""
    echo " Synth-Shell Install will launch in 5 seconds..."
    sleep 5
    $INSTALL_PATH/packages/synth-shell/setup.sh 2>&1 | tee -a $LOG
    sleep 5

    ############### Setup Settings, Taskbar and Background Image
