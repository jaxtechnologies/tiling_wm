#!/bin/sh

# Get battery percentage
perc=$(cat /sys/class/power_supply/BAT0/capacity)
# Get status (Charging/Discharging)
status=$(cat /sys/class/power_supply/BAT0/status)

if [ "$status" = "Charging" ]; then
    echo "🔌 $perc% 🔺 "
elif [ "$status" = "Discharging" ]; then
    echo "🔋 $perc% 🔻 "
else
    echo "🔌 "
fi

